<?xml version="1.0"?>
<gpx version="1.1">
  <trk>
    <trkseg>
      <trkpt lat="50.515" lon="-2.458">
        <time>2024-01-01T10:00:00Z</time>
      </trkpt>
      <!-- Invalid time format -->
      <trkpt lat="50.516" lon="-2.457">
        <time>not_a_date</time>
      </trkpt>
      <!-- Malformed ISO timestamp -->
      <trkpt lat="50.517" lon="-2.456">
        <time>2024-13-45T25:99:99Z</time>
      </trkpt>
      <!-- Missing time element -->
      <trkpt lat="50.518" lon="-2.455">
      </trkpt>
    </trkseg>
  </trk>
</gpx>