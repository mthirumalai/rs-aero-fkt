<?xml version="1.0"?>
<gpx version="1.1">
  <trk>
    <trkseg>
      <trkpt lat="50.515" lon="-2.458">
        <time>2024-01-01T10:00:00Z</time>
      </trkpt>
      <!-- Invalid latitude (text instead of number) -->
      <trkpt lat="not_a_number" lon="-2.457">
        <time>2024-01-01T10:01:00Z</time>
      </trkpt>
      <!-- Invalid longitude (out of range) -->
      <trkpt lat="50.517" lon="999.999">
        <time>2024-01-01T10:02:00Z</time>
      </trkpt>
      <!-- Both coordinates invalid -->
      <trkpt lat="abc" lon="def">
        <time>2024-01-01T10:03:00Z</time>
      </trkpt>
    </trkseg>
  </trk>
</gpx>