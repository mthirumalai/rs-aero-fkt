# Copy this to .env for local development
# (The real .env is gitignored)

# ── Local dev flag ───────────────────────────────────────────────────────────
# Set to "true" to use local filesystem instead of S3, and console.log instead of SES
USE_LOCAL_DEV=true

# Directory for uploaded files (relative to project root)
LOCAL_UPLOAD_DIR=./local-uploads

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL 16 via Homebrew (brew services start postgresql@16)
DATABASE_URL="postgresql://$(whoami)@localhost:5432/rsaerofkt"

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-secret"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Apple OAuth (optional for local dev) ─────────────────────────────────────
# Leave blank to disable Apple sign-in locally
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── AWS (not needed when USE_LOCAL_DEV=true) ─────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_GPX="rs-aero-fkt-gpx"
S3_BUCKET_PHOTOS="rs-aero-fkt-photos"
SES_FROM_EMAIL=""
ADMIN_EMAIL="your-email@example.com"
