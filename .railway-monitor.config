# Railway Deployment Monitoring Configuration
# Edit this file to update monitoring settings

# Railway app URL to health check
RAILWAY_APP_URL="https://rs-aero-fkt-production.up.railway.app"

# Monitoring settings
MONITOR_TIMEOUT=900  # 15 minutes max monitoring time
POLL_INTERVAL=30     # Check status every 30 seconds
MAX_RETRIES=3        # Maximum fix attempts before asking for help

# Notification settings
NOTIFY_BRIEF=true    # Brief updates only